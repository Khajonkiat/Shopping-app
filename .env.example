# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=shopping_app
DB_SSLMODE=disable

# ── Backend ───────────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -hex 32
JWT_SECRET=change-me

# Master account provisioned at first startup (idempotent)
MASTER_EMAIL=admin@example.com
MASTER_USERNAME=master
MASTER_PASSWORD=change-me

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the backend API — baked into the frontend at build time.
# Must be the URL users' browsers will reach (not the internal Docker hostname).
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1
